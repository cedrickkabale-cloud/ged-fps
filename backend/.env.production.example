# Serveur
PORT=5000
NODE_ENV=production

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ged_fps
DB_USER=postgres
DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_super_secret_jwt_key
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS (URL du frontend public)
FRONTEND_URL=https://votre-domaine.com

# SMTP — Brevo gratuit (300 emails/jour, aucun coût)
# 1. Créer un compte sur https://app.brevo.com
# 2. Aller dans Settings > SMTP & API > SMTP
# 3. Copier Login (SMTP_USER) et le mot de passe SMTP généré (SMTP_PASS)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre_cle_smtp_brevo
MAIL_FROM="GED FPS <no-reply@votre-domaine.com>"

# Alternative payante : Hostinger Email (~2 USD/mois)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=no-reply@votre-domaine.com
# SMTP_PASS=change_me

# URL publique frontend pour les liens email
APP_URL=https://votre-domaine.com

# OCR / Queue tuning
OCR_POLL_INTERVAL_MS=3000
OCR_MAX_ATTEMPTS=3
OCR_RETRY_DELAY_MS=30000
OCR_MIN_TEXT_LENGTH=40
OCR_MAX_PDF_PAGES=20
