# Serveur
PORT=5000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ged_fps
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_very_secure_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
FRONTEND_URL=http://localhost:3000

# SMTP — Brevo gratuit (300 emails/jour, aucun coût)
# 1. Créer un compte sur https://app.brevo.com
# 2. Aller dans Settings > SMTP & API > SMTP
# 3. Copier Login (SMTP_USER) et le mot de passe SMTP généré (SMTP_PASS)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre_cle_smtp_brevo
MAIL_FROM="GED FPS <no-reply@votre-domaine.com>"

# URL publique du frontend pour les liens email
APP_URL=http://localhost:3000
